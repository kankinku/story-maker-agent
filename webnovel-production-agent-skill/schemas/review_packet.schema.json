{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Webnovel Review Packet",
  "type": "object",
  "required": ["schema_version", "review_id", "project_id", "task_id", "draft_path", "final_path", "context_used", "component_versions", "checks", "uncertainties", "review_questions", "human_outcome"],
  "properties": {
    "schema_version": {"const": "1.0.0"}, "review_id": {"type": "string", "minLength": 1}, "project_id": {"type": "string", "minLength": 1}, "task_id": {"type": "string", "minLength": 1},
    "draft_path": {"type": "string", "minLength": 1}, "final_path": {"type": "string", "minLength": 1},
    "context_used": {"type": "array", "minItems": 1, "items": {"type": "object", "required": ["source_id", "source_version", "source_hash"], "properties": {"source_id": {"type": "string"}, "source_version": {"type": "string"}, "source_hash": {"type": "string"}}, "additionalProperties": false}},
    "component_versions": {"type": "object", "minProperties": 1, "additionalProperties": {"type": "string"}},
    "checks": {"type": "object", "required": ["grounding", "canon", "character_state", "continuity", "style"], "properties": {"grounding": {"enum": ["pass", "fail", "blocked"]}, "canon": {"enum": ["pass", "fail", "blocked"]}, "character_state": {"enum": ["pass", "fail", "blocked"]}, "continuity": {"enum": ["pass", "fail", "blocked"]}, "style": {"enum": ["pass", "fail", "blocked"]}}, "additionalProperties": true},
    "uncertainties": {"type": "array", "items": {"type": "string"}}, "review_questions": {"type": "array", "items": {"type": "string"}},
    "human_outcome": {"type": "object", "required": ["status", "reviewed_at"], "properties": {"status": {"enum": ["accepted_without_edit", "edited_and_approved", "rejected", "held", "pending"]}, "reviewed_at": {"type": ["string", "null"], "format": "date-time"}, "reviewer": {"type": "string"}}, "additionalProperties": false}
  },
  "additionalProperties": false
}
