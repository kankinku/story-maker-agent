{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Hash-bound Source Rewrite Fidelity Contract",
  "type": "object",
  "required": [
    "schema_version",
    "source",
    "rewrite",
    "source_events",
    "rewrite_events",
    "preserve_entities",
    "rewrite_entities",
    "allowed_entity_renames",
    "protected_quotes",
    "rewrite_quotes"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "source": {"$ref": "#/$defs/file_binding"},
    "rewrite": {"$ref": "#/$defs/file_binding"},
    "source_events": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/source_event"}
    },
    "rewrite_events": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/rewrite_event"}
    },
    "preserve_entities": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "rewrite_entities": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "allowed_entity_renames": {"type": "object", "additionalProperties": {"type": "string", "minLength": 1}},
    "protected_quotes": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "rewrite_quotes": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
  },
  "$defs": {
    "file_binding": {
      "type": "object",
      "required": ["path", "sha256"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
      },
      "additionalProperties": false
    },
    "source_event": {
      "type": "object",
      "required": ["event_id", "order", "summary", "required"],
      "properties": {
        "event_id": {"type": "string", "minLength": 1},
        "order": {"type": "integer", "minimum": 1},
        "summary": {"type": "string", "minLength": 1},
        "required": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "rewrite_event": {
      "type": "object",
      "required": ["event_id", "order", "summary", "source_event_id", "approved_invention"],
      "properties": {
        "event_id": {"type": "string", "minLength": 1},
        "order": {"type": "integer", "minimum": 1},
        "summary": {"type": "string", "minLength": 1},
        "source_event_id": {"type": ["string", "null"]},
        "approved_invention": {"type": "boolean"}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
