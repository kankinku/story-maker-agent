{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Context Compounding Offline Replay Evaluation",
  "type": "object",
  "required": ["schema_version", "proposal_id", "cases", "minimum_average", "critical_dimensions"],
  "properties": {
    "schema_version": {"const": "1.0.0"}, "proposal_id": {"type": "string"}, "minimum_average": {"type": "number", "minimum": 1, "maximum": 5},
    "critical_dimensions": {"type": "array", "uniqueItems": true, "items": {"enum": ["result_quality", "canon_fidelity", "state_continuity", "process_compliance", "style_fit", "efficiency"]}},
    "cases": {"type": "array", "minItems": 1, "items": {"type": "object", "required": ["case_id", "current_output", "candidate_output", "human_final", "scores", "critical_failures"], "properties": {
      "case_id": {"type": "string"}, "current_output": {"type": "string"}, "candidate_output": {"type": "string"}, "human_final": {"type": "string"},
      "scores": {"type": "object", "required": ["result_quality", "canon_fidelity", "state_continuity", "process_compliance", "style_fit", "efficiency"], "additionalProperties": false, "properties": {
        "result_quality": {"$ref": "#/$defs/comparison"}, "canon_fidelity": {"$ref": "#/$defs/comparison"}, "state_continuity": {"$ref": "#/$defs/comparison"}, "process_compliance": {"$ref": "#/$defs/comparison"}, "style_fit": {"$ref": "#/$defs/comparison"}, "efficiency": {"$ref": "#/$defs/comparison"}
      }},
      "critical_failures": {"type": "object", "required": ["current", "candidate"], "properties": {"current": {"type": "array", "items": {"type": "string"}}, "candidate": {"type": "array", "items": {"type": "string"}}}, "additionalProperties": false}
    }, "additionalProperties": false}}
  },
  "$defs": {"comparison": {"type": "object", "required": ["current", "candidate", "evidence"], "properties": {"current": {"type": "number", "minimum": 1, "maximum": 5}, "candidate": {"type": "number", "minimum": 1, "maximum": 5}, "evidence": {"type": "string"}}, "additionalProperties": false}},
  "additionalProperties": false
}
