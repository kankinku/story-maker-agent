{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Webnovel Review Diff",
  "type": "object",
  "required": ["schema_version", "diff_id", "review_id", "scope", "draft_path", "final_path", "draft_hash", "final_hash", "classifications", "root_cause_hypotheses", "completed", "reviewed_at"],
  "properties": {
    "schema_version": {"const": "1.0.0"}, "diff_id": {"type": "string"}, "review_id": {"type": "string"}, "scope": {"type": "string", "minLength": 1}, "draft_path": {"type": "string"}, "final_path": {"type": "string"}, "draft_hash": {"type": "string"}, "final_hash": {"type": "string"},
    "similarity_ratio": {"type": "number", "minimum": 0, "maximum": 1}, "added_lines": {"type": "integer", "minimum": 0}, "removed_lines": {"type": "integer", "minimum": 0},
    "classifications": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"enum": ["STYLE_PREFERENCE", "CANON_FACT_MISSING", "CANON_CONTRADICTION", "CHARACTER_STATE_DRIFT", "RELATIONSHIP_DRIFT", "STRUCTURE_CHANGE", "RETRIEVAL_MISS", "STALE_CONTEXT", "POLICY_VIOLATION", "HUMAN_JUDGMENT"]}},
    "root_cause_hypotheses": {"type": "array", "minItems": 3, "items": {"type": "object", "required": ["cause", "target", "evidence", "confidence"], "properties": {"cause": {"type": "string"}, "target": {"enum": ["retrieval", "state", "prompt", "validator", "policy", "human_judgment"]}, "evidence": {"type": "string"}, "confidence": {"type": "number", "minimum": 0, "maximum": 1}}, "additionalProperties": false}},
    "completed": {"type": "boolean"}, "reviewed_at": {"type": "string", "format": "date-time"}
  },
  "additionalProperties": false
}
