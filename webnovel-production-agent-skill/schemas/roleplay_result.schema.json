{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Webnovel Pre-draft Roleplay Result",
  "type": "object",
  "required": ["schema_version", "project_id", "episode_number", "scene_id", "source_state_version", "participants", "writer_use"],
  "properties": {
    "schema_version": {"const": "1.0.0"}, "project_id": {"type": "string"}, "episode_number": {"type": "integer", "minimum": 1}, "scene_id": {"type": "string"}, "source_state_version": {"type": "string"},
    "participants": {"type": "array", "minItems": 1, "items": {"type": "object", "required": ["character_id", "known_facts", "desire", "concealed_information", "expected_action", "speech_purpose", "emotion_before", "emotion_after"], "properties": {
      "character_id": {"type": "string"}, "known_facts": {"type": "array", "items": {"type": "string"}}, "desire": {"type": "string"}, "concealed_information": {"type": "array", "items": {"type": "string"}}, "expected_action": {"type": "string"}, "speech_purpose": {"type": "string"}, "emotion_before": {"type": "string"}, "emotion_after": {"type": "string"}
    }, "additionalProperties": false}},
    "writer_use": {"const": "structured_input_only_not_prose"}
  },
  "additionalProperties": false
}
